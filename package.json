{
  "name": "suirobo-app",
  "private": true,
  "version": "1.2.0",
  "description": "Autobots — self-custody DeepBook trading bot desktop app",
  "author": "Team Autobots",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "agent": "npx tsx server/local_agent.ts",
    "agent:bootstrap": "npx tsx server/agent_bootstrap.ts",
    "agent:build": "node build_agent.cjs",
    "agent:publish": "node publish_agent.cjs",
    "agent:dist": "npm run agent:build && npm run agent:publish",
    "deploy": "npx tsx deploy_walrus.ts",
    "deploy:site": "npm run build && site-builder --wallet-address 0xafbc48fd349fb44ce9c6f2b33423e6ae7c826d53a25920a0d4c3c475e40889c5 update ./dist 0xf070fa29afac7f54de6f849d6e4391b181ba511205e1e4474cf58bfa39537a81 --epochs 10",
    "app": "electron electron/main.cjs",
    "app:build": "npm run build && npm run agent:build && electron electron/main.cjs",
    "dist:win": "npm run build && npm run agent:build && electron-builder --win portable"
  },
  "build": {
    "appId": "app.autobots.desktop",
    "productName": "Autobots",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-agent/agent-bundle.cjs",
        "to": "dist-agent/agent-bundle.cjs"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "dist-agent/suirobo.ico"
    },
    "portable": {
      "artifactName": "Autobots.exe"
    }
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@google/genai": "^2.7.0",
    "@mysten-incubation/memwal": "^0.0.4",
    "@mysten-incubation/oc-memwal": "^0.0.2",
    "@mysten/bcs": "^2.0.5",
    "@mysten/dapp-kit": "^1.0.6",
    "@mysten/deepbook-v3": "^1.4.1",
    "@mysten/sui": "^2.17.0",
    "@tanstack/react-query": "^5.100.9",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "node-fetch": "^3.3.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reactflow": "^11.11.4",
    "selfsigned": "^5.5.0",
    "technicalindicators": "^3.1.0",
    "ws": "^8.21.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@yao-pkg/pkg": "^6.20.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "png-to-ico": "^3.0.1",
    "puppeteer": "^25.0.4",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-node-polyfills": "^0.22.0"
  }
}
